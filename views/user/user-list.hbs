<h1>用户列表</h1>
<div class='d-flex justify-content-end'>
  <a href='/admin/users/create' class='btn btn-success mb-3 right'>添加用户</a>
</div>
<table class='table'>
  <thead>
    <tr>
      <th>用户名</th>
      <th>邮箱</th>
    </tr>
  </thead>
  <tbody>
    {{#each users}}
      <tr>
        <td>{{this.username}}</td>
        <td>{{this.email}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>