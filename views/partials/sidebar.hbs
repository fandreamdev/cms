<div class='col-md-3 col-lg-2 p-0'>
  <div class='accordion' id='sidebarMenu'>
    <div class='accordion-item'>
      <h2 class='accordion-header' id='heading'>
        <button
          class='accordion-button {{#unless (isPermissionMenuOpen currentPath)}}collapsed{{/unless}}'
          type='button'
          data-bs-toggle='collapse'
          data-bs-target='#collapse1'
          aria-expanded='{{#if (isPermissionMenuOpen currentPath)}}true{{else}}false{{/if}}'
        >
          {{t 'menu.permission'}}
        </button>
      </h2>
      <div
        class='accordion-collapse collapse {{#if (isPermissionMenuOpen currentPath)}}show{{/if}}'
        id='collapse1'
      >
        <div class='accordion-body'>
          <ul class='list-group'>
            <li class='list-group-item'>
              <a href='/admin/users'>{{t 'menu.user_management'}}</a>
            </li>
            <li class='list-group-item'>
              <a href='/admin/roles'>{{t 'menu.role_management'}}</a>
            </li>

          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
