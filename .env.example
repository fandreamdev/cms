DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_DB=cms

# 网站设置使用 MongoDB（执行 docker compose up -d 后可直接使用以下本地地址）
MONGODB_URI=mongodb://cms:cms_local_password@localhost:27017/cms?authSource=admin
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
# docker-compose.yml 的 MongoDB 容器变量；生产环境请替换强密码
MONGODB_ROOT_USERNAME=cms
MONGODB_ROOT_PASSWORD=cms_local_password
MONGODB_DATABASE=cms
MONGODB_PORT=27017

# 仪表盘天气（Open-Meteo 不需要 API Key；其他供应商的 Key 仅应保存在环境变量）
WEATHER_PROVIDER=open-meteo
WEATHER_API_KEY=
WEATHER_DEFAULT_LATITUDE=31.2304
WEATHER_DEFAULT_LONGITUDE=121.4737
WEATHER_DEFAULT_NAME=上海
WEATHER_CACHE_TTL_SECONDS=900
WEATHER_TIMEOUT_MS=5000

# 系统监控：实例标识为脱敏展示字段；使用率阈值均为 0–100 的数字
SYSTEM_INSTANCE_ID=cms-api
SYSTEM_INSTANCE_HOSTNAME=
SYSTEM_MONITOR_HISTORY_SIZE=60
SYSTEM_MONITOR_INTERVAL_MS=3000
SYSTEM_MONITOR_MAX_CONNECTIONS_PER_USER=3
SYSTEM_MONITOR_CPU_WARNING=75
SYSTEM_MONITOR_CPU_CRITICAL=90
SYSTEM_MONITOR_MEMORY_WARNING=75
SYSTEM_MONITOR_MEMORY_CRITICAL=90
SYSTEM_MONITOR_DISK_WARNING=75
SYSTEM_MONITOR_DISK_CRITICAL=90
SYSTEM_MONITOR_EVENT_LOOP_WARNING_MS=100
SYSTEM_MONITOR_EVENT_LOOP_CRITICAL_MS=500

# 兼容旧配置，同时作为 accessToken 密钥的默认值
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7200
# 推荐生产环境分别配置两个不同的随机密钥
JWT_ACCESS_SECRET=replace-with-an-access-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_SECRET=replace-with-a-refresh-secret-at-least-32-characters
JWT_REFRESH_EXPIRES_IN=604800

# 文章提交审批邮件；未启用时只记录跳过日志
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=CMS <no-reply@example.com>
EMAIL_CONNECTION_TIMEOUT_MS=10000
# 可选：邮件中的“前往文章审核”链接
EMAIL_ARTICLE_REVIEW_URL=https://cms.example.com/admin/reviews/articles

# 可选：PDF 导出使用的中文 TTF/OTF/TTC 字体；常见系统字体会自动探测
ARTICLE_EXPORT_PDF_FONT_PATH=
# 仅 TTC 字体集合需要填写，例如 Noto Sans CJK SC
ARTICLE_EXPORT_PDF_FONT_FAMILY=

# 图片存储：未配置时默认 local，可选 oss
UPLOAD_STORAGE=local
UPLOAD_LOCAL_DIRECTORY=uploads
# 可选；配置后本地上传返回完整 URL，例如 https://cms.example.com
UPLOAD_PUBLIC_BASE_URL=
# 图片压缩：最大宽度（不放大小图）与有损格式质量
UPLOAD_IMAGE_MAX_WIDTH=1920
UPLOAD_IMAGE_QUALITY=82

# UPLOAD_STORAGE=oss 时必填
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# 可选：自定义 OSS Endpoint 和 CDN 域名
OSS_ENDPOINT=
OSS_CDN_URL=
