DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_DB=cms

# 图片存储：未配置时默认 local，可选 oss
UPLOAD_STORAGE=local
UPLOAD_LOCAL_DIRECTORY=uploads
# 可选；配置后本地上传返回完整 URL，例如 https://cms.example.com
UPLOAD_PUBLIC_BASE_URL=

# UPLOAD_STORAGE=oss 时必填
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# 可选：自定义 OSS Endpoint 和 CDN 域名
OSS_ENDPOINT=
OSS_CDN_URL=
